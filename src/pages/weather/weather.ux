  font-size: 19px;
  font-weight: bold;
  line-height: 28px;
}

.alert-detail {
  margin-top: 8px;
  font-size: 18px;
  line-height: 26px;
}

/* 7天预报 — 增大行高和间距 */
.section-card {
  margin-top: 18px;
  padding: 20px;
  border-radius: 8px;
  flex-direction: column;
}

.section-title {
  font-size: 20px;
  font-weight: bold;
  margin-bottom: 20px;
}

