<template>
  <div class="page {{ isDark ? 'page-dark' : 'page-light' }}">
    <div class="side-bar {{ isDark ? 'side-bar-dark' : 'side-bar-light' }}">
      <div class="brand-block">
        <text class="brand-en">INFOPLAT</text>
        <text class="brand-title {{ isDark ? 'text-dark' : 'text-light' }}">信息台</text>
      </div>

      <div class="time-block">
        <text class="time-text {{ isDark ? 'text-dark' : 'text-light' }}">{{ currentTime }}</text>
        <text class="mode-text {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ modeLabel }}</text>
      </div>

      <div class="nav-block">
        <input class="nav-button {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="首页" onclick="goHome" />
        <input class="nav-button {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="新闻" onclick="goNews" />
        <input class="nav-button nav-button-active" type="button" value="天气" />
        <input class="nav-button {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="快递" onclick="goExpress" />
      </div>

      <input class="theme-button {{ isDark ? 'theme-btn-dark' : 'theme-btn-light' }}" type="button" value="{{ themeButtonText }}" onclick="toggleTheme" />
    </div>

    <div class="main-panel {{ isDark ? 'main-panel-dark' : 'main-panel-light' }}">
      <!-- ======== 天气主视图 ======== -->
      <div class="weather-view" if="{{ !showCityPicker }}">
        <div class="action-row">
          <input class="city-select-btn {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="{{ selectedCity }}" onclick="openCityPicker" />
          <input class="refresh-button" type="button" value="刷新" onclick="loadWeatherData" />
        </div>

        <scroll class="weather-panel" scroll-y="true" bounces="true">
          <!-- 预警 -->
          <div for="{{ weatherInfo.alerts }}">
            <div class="alert-bar {{ isDark ? 'card-dark' : 'card-light' }}" onclick="toggleAlert($idx)">
              <text class="alert-text">{{ $item.title }}</text>
              <div class="alert-detail-wrap" if="{{ expandedAlertIdx === $idx }}">
                <text class="alert-detail-title {{ isDark ? 'text-dark' : 'text-light' }}" if="{{ $item.alertTitle }}">{{ $item.alertTitle }}</text>
                <text class="alert-detail {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}" if="{{ $item.desc }}">{{ $item.desc }}</text>
              </div>
            </div>
          </div>

          <!-- 当日天气主卡片 -->
          <div class="lead-card {{ isDark ? 'card-dark' : 'card-light' }}">
            <div class="lead-left">
              <text class="lead-city {{ isDark ? 'text-dark' : 'text-light' }}">{{ weatherInfo.title }}</text>
              <text class="lead-desc {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ weatherInfo.subtitle }}</text>
            </div>
            <text class="lead-temp {{ isDark ? 'text-dark' : 'text-light' }}">{{ weatherInfo.message }}</text>
          </div>

          <!-- 当日主要数据网格 -->
          <div class="detail-grid">
            <div class="detail-card {{ isDark ? 'card-dark' : 'card-light' }}" for="{{ weatherInfo.details }}">
              <text class="detail-label {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ $item.label }}</text>
              <text class="detail-value {{ isDark ? 'text-dark' : 'text-light' }}">{{ $item.value }}</text>
            </div>
          </div>

          <!-- 7天预报 -->
          <div class="section-card {{ isDark ? 'card-dark' : 'card-light' }}" if="{{ weatherInfo.forecasts.length > 0 }}">
            <text class="section-title {{ isDark ? 'text-dark' : 'text-light' }}">7天预报</text>
            <div for="{{ weatherInfo.forecasts }}">
              <div class="forecast-row {{ isDark ? 'card-dark' : 'card-light' }}">
                <text class="forecast-day {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ $item.day }}</text>
                <text class="forecast-info {{ isDark ? 'text-dark' : 'text-light' }}">{{ $item.info }}</text>
              </div>
            </div>
          </div>

          <!-- 次要天气数据 -->
          <div class="detail-grid" if="{{ weatherInfo.detailsExtra.length > 0 }}">
            <div class="detail-card {{ isDark ? 'card-dark' : 'card-light' }}" for="{{ weatherInfo.detailsExtra }}">
              <text class="detail-label {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ $item.label }}</text>
              <text class="detail-value {{ isDark ? 'text-dark' : 'text-light' }}">{{ $item.value }}</text>
            </div>
          </div>

          <!-- 生活指数 -->
          <div class="section-card {{ isDark ? 'card-dark' : 'card-light' }}" if="{{ weatherInfo.indexes.length > 0 }}">
            <text class="section-title {{ isDark ? 'text-dark' : 'text-light' }}">生活指数</text>
            <div for="{{ weatherInfo.indexes }}">
              <div class="index-item {{ isDark ? 'card-dark' : 'card-light' }}">
                <text class="index-name {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ $item.name }}</text>
                <text class="index-brief {{ isDark ? 'text-dark' : 'text-light' }}">{{ $item.brief }}</text>
                <text class="index-detail {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}" if="{{ $item.detail }}">{{ $item.detail }}</text>
              </div>
            </div>
          </div>
        </scroll>
      </div>

      <!-- ======== 城市选择视图 ======== -->
      <div class="picker-view" if="{{ showCityPicker }}">
        <div class="picker-header">
          <input class="picker-back-btn {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="{{ pickerLevel > 0 ? '返回' : '关闭' }}" onclick="pickerBack" />
          <text class="picker-title {{ isDark ? 'text-dark' : 'text-light' }}">{{ pickerTitle }}</text>
        </div>

        <div class="breadcrumb" if="{{ pickerLevel > 0 }}">
          <input class="breadcrumb-link" type="button" value="全部地区" onclick="jumpToRegion" />
          <text class="breadcrumb-sep {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}" if="{{ pickerLevel >= 1 }}"> ></text>
          <input class="breadcrumb-link" type="button" value="{{ regionLabel }}" onclick="jumpToProvince" if="{{ pickerLevel >= 1 }}" />
          <text class="breadcrumb-sep {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}" if="{{ pickerLevel === 2 }}"> ></text>
          <text class="breadcrumb-current {{ isDark ? 'text-dark' : 'text-light' }}" if="{{ pickerLevel === 2 }}">{{ provinceLabel }}</text>
        </div>

        <div class="picker-body">
          <!-- 地区列表：7个按钮，两列布局 -->
          <div class="picker-list" if="{{ pickerLevel === 0 }}">
            <div class="picker-row">
              <input class="picker-btn {{ isDark ? 'picker-btn-dark' : '' }}" type="button" value="华北" onclick="pickRegion(0)" />
              <input class="picker-btn {{ isDark ? 'picker-btn-dark' : '' }}" type="button" value="东北" onclick="pickRegion(1)" />
            </div>
            <div class="picker-row">
              <input class="picker-btn {{ isDark ? 'picker-btn-dark' : '' }}" type="button" value="华东" onclick="pickRegion(2)" />
              <input class="picker-btn {{ isDark ? 'picker-btn-dark' : '' }}" type="button" value="华中" onclick="pickRegion(3)" />
            </div>
            <div class="picker-row">
              <input class="picker-btn {{ isDark ? 'picker-btn-dark' : '' }}" type="button" value="华南" onclick="pickRegion(4)" />
              <input class="picker-btn {{ isDark ? 'picker-btn-dark' : '' }}" type="button" value="西南" onclick="pickRegion(5)" />
            </div>
            <div class="picker-row">
              <input class="picker-btn {{ isDark ? 'picker-btn-dark' : '' }}" type="button" value="西北" onclick="pickRegion(6)" />
            </div>
          </div>

          <!-- 省份列表（双列） -->
          <scroll class="picker-scroll" scroll-y="true" bounces="true" if="{{ pickerLevel === 1 }}">
            <div class="picker-wrap">
              <input class="picker-btn {{ isDark ? 'picker-btn-dark' : '' }}" type="button" for="{{ pickerList }}" value="{{ $item }}" onclick="pickProvince($idx)" />
            </div>
          </scroll>

          <!-- 城市列表（双列） -->
          <scroll class="picker-scroll" scroll-y="true" bounces="true" if="{{ pickerLevel === 2 }}">
            <div class="picker-wrap">
              <input class="picker-btn {{ isDark ? 'picker-btn-dark' : '' }}" type="button" for="{{ pickerList }}" value="{{ $item }}" onclick="pickCity($idx)" />
            </div>
          </scroll>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import router from "@system.router"
import storage from "@system.storage"
import { getWeather } from "../../common/services"
import { getThemeSync, initTheme, setTheme } from "../../common/theme"
import { getCached, setCache } from "../../common/cache"
import { regions } from "../../common/cities"

function pad(value) {
  return value < 10 ? "0" + value : "" + value
}

var CITY_STORAGE_KEY = "infoWeatherCity"

export default {
  private: {
    isDark: false,
    themeButtonText: "深色模式",
    modeLabel: "浅色",
    currentTime: "--:--",
    selectedCity: "北京",
    showCityPicker: false,
    pickerLevel: 0,
    pickerTitle: "选择地区",
    pickerList: [],
    regionLabel: "",
    provinceLabel: "",
    selectedRegionIdx: -1,
    selectedProvinceIdx: -1,
    expandedAlertIdx: -1,
    weatherInfo: {
      title: "北京",
      subtitle: "正在获取天气...",
      message: "--°C",
      details: [],
      detailsExtra: [],
      indexes: [],
      forecasts: [],
      alerts: []
    }
  },

  onInit() {
    var self = this
    initTheme(function (isDark) {
      self.isDark = isDark
      self.themeButtonText = isDark ? "浅色模式" : "深色模式"
      self.modeLabel = isDark ? "深色" : "浅色"
    })
    this.updateClock()
    this.loadSavedCity()
  },

  onShow() {
    this.updateClock()
  },

  updateClock() {
    var now = new Date()
    this.currentTime = pad(now.getHours()) + ":" + pad(now.getMinutes())
  },

  toggleTheme() {
    this.isDark = !this.isDark
    this.themeButtonText = this.isDark ? "浅色模式" : "深色模式"
    this.modeLabel = this.isDark ? "深色" : "浅色"
    setTheme(this.isDark)
  },

  goHome() {
    router.push({ uri: "pages/index" })
  },

  goNews() {
    router.back()
  },

  goExpress() {
    router.push({ uri: "pages/express" })
  },

  loadSavedCity() {
    var self = this
    storage.get({
      key: CITY_STORAGE_KEY,
      success: function (data) {
        if (data) {
          self.selectedCity = data
        }
        self.loadWeatherData()
      },
      fail: function () {
        self.loadWeatherData()
      }
    })
  },

  saveCity(city) {
    storage.set({
      key: CITY_STORAGE_KEY,
      value: city
    })
  },

  toggleAlert(idx) {
    this.expandedAlertIdx = this.expandedAlertIdx === idx ? -1 : idx
  },

  openCityPicker() {
    this.pickerLevel = 0
    this.pickerTitle = "选择地区"
    this.regionLabel = ""
    this.provinceLabel = ""
    this.selectedRegionIdx = -1
    this.selectedProvinceIdx = -1
    this.pickerList = []
    this.showCityPicker = true
  },

  pickRegion(idx) {
    this.selectedRegionIdx = idx
    this.regionLabel = regions[idx].name
    this.pickerTitle = regions[idx].name
    var names = []
    var provs = regions[idx].provinces
    for (var i = 0; i < provs.length; i++) {
      names.push(provs[i].name)
    }
    this.pickerList = names
    this.pickerLevel = 1
  },

  pickProvince(idx) {
    if (this.selectedRegionIdx < 0 || idx < 0) return
    var provs = regions[this.selectedRegionIdx].provinces
    if (idx >= provs.length) return
    this.selectedProvinceIdx = idx
    this.provinceLabel = provs[idx].name
    this.pickerTitle = this.provinceLabel
    this.pickerList = provs[idx].cities
    this.pickerLevel = 2
  },

  pickCity(idx) {
    if (idx < 0 || idx >= this.pickerList.length) return
    this.selectedCity = this.pickerList[idx]
    this.saveCity(this.selectedCity)
    this.showCityPicker = false
    this.loadWeatherData()
  },

  pickerBack() {
    if (this.pickerLevel === 2) {
      this.pickerLevel = 1
      this.pickerTitle = this.regionLabel
      var provs = regions[this.selectedRegionIdx].provinces
      var names = []
      for (var i = 0; i < provs.length; i++) {
        names.push(provs[i].name)
      }
      this.pickerList = names
    } else if (this.pickerLevel === 1) {
      this.pickerLevel = 0
      this.pickerTitle = "选择地区"
      this.regionLabel = ""
      this.provinceLabel = ""
      this.selectedRegionIdx = -1
      this.pickerList = []
    } else {
      this.showCityPicker = false
    }
  },

  jumpToRegion() {
    this.pickerLevel = 0
    this.pickerTitle = "选择地区"
    this.regionLabel = ""
    this.provinceLabel = ""
    this.selectedRegionIdx = -1
    this.pickerList = []
  },

  jumpToProvince() {
    if (this.selectedRegionIdx < 0) return
    this.pickerLevel = 1
    this.pickerTitle = this.regionLabel
    var provs = regions[this.selectedRegionIdx].provinces
    var names = []
    for (var i = 0; i < provs.length; i++) {
      names.push(provs[i].name)
    }
    this.pickerList = names
  },

  loadWeatherData() {
    var city = this.selectedCity
    var cacheKey = "weather_" + city
    var cached = getCached(cacheKey)
    if (cached) {
      this.weatherInfo = cached
      return
    }
    getWeather(city).then((info) => {
      setCache(cacheKey, info, 10 * 60 * 1000)
      this.weatherInfo = info
      this.expandedAlertIdx = -1
    }).catch(() => {
      this.weatherInfo = {
        title: city,
        subtitle: "天气获取失败",
        message: "--°C",
        details: [],
        detailsExtra: [],
        indexes: [],
        forecasts: [],
        alerts: []
      }
    })
  }
}
</script>

<style>
text {
  color: #172026;
  font-size: 20px;
  line-height: 26px;
}

