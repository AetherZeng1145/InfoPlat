<template>
  <div class="page">
    <div class="topbar">
      <input class="back-btn" type="button" value="返回" onclick="goBack" />
      <text class="source">{{ source }}</text>
    </div>
    <div class="article">
      <text class="title">{{ title }}</text>
      <text class="desc">{{ description }}</text>
      <text class="url">{{ url }}</text>
    </div>
  </div>
</template>

<script>
import router from "@system.router"

export default {
  private: {
    title: "新闻详情",
    description: "暂无摘要",
    source: "InfoPlat",
    url: ""
  },

  onInit() {
    if (this.$page && this.$page.params) {
      this.title = this.$page.params.title || this.title
      this.description = this.$page.params.description || this.description
      this.source = this.$page.params.source || this.source
      this.url = this.$page.params.url || this.url
    }
  },

  goBack() {
    router.back()
  }
}
</script>

