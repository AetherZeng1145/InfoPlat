<template>
  <div class="page {{ isDark ? 'page-dark' : 'page-light' }}">
    <div class="side-bar {{ isDark ? 'side-bar-dark' : 'side-bar-light' }}">
      <div class="brand-block">
        <text class="brand-en">INFOPLAT</text>
        <text class="brand-title {{ isDark ? 'text-dark' : 'text-light' }}">信息台</text>
      </div>

      <div class="time-block">
        <text class="time-text {{ isDark ? 'text-dark' : 'text-light' }}">{{ currentTime }}</text>
        <text class="mode-text {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ modeLabel }}</text>
      </div>

      <div class="nav-block">
        <input class="{{ newsNavClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="新闻" onclick="showNews" />
        <input class="{{ weatherNavClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="天气" onclick="showWeather" />
        <input class="{{ expressNavClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="快递" onclick="showExpress" />
      </div>

      <input class="theme-button {{ isDark ? 'theme-btn-dark' : 'theme-btn-light' }}" type="button" value="{{ themeButtonText }}" onclick="toggleTheme" />
    </div>

    <div class="main-panel {{ isDark ? 'main-panel-dark' : 'main-panel-light' }}">
      <div class="action-row">
        <scroll class="category-scroll" scroll-x="true" scroll-y="false" bounces="true" if="{{ showNewsPanel }}">
          <div class="category-track">
            <input class="{{ allCategoryClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="综合新闻" onclick="loadNewsAll" />
            <input class="{{ worldCategoryClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="国际新闻" onclick="loadNewsWorld" />
            <input class="{{ techCategoryClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="科技新闻" onclick="loadNewsTech" />
            <input class="{{ businessCategoryClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="财经新闻" onclick="loadNewsBusiness" />
            <input class="{{ sportsCategoryClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="体育新闻" onclick="loadNewsSports" />
            <input class="{{ entertainmentCategoryClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="娱乐新闻" onclick="loadNewsEntertainment" />
            <input class="{{ scienceCategoryClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="科学新闻" onclick="loadNewsScience" />
            <input class="{{ politicsCategoryClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="政治新闻" onclick="loadNewsPolitics" />
            <input class="{{ healthCategoryClass }} {{ isDark ? 'btn-dark' : 'btn-light' }}" type="button" value="健康新闻" onclick="loadNewsHealth" />
          </div>
        </scroll>
        <input class="refresh-button" type="button" value="{{ actionText }}" onclick="refreshCurrent" />
      </div>

      <div class="state-box" if="{{ loading }}">
        <text class="state-title {{ isDark ? 'text-dark' : 'text-light' }}">正在加载</text>
        <text class="state-text {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ stateText }}</text>
      </div>

      <div class="state-box" if="{{ hasError }}">
        <text class="state-title error-title">加载失败</text>
        <text class="state-text {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ errorText }}</text>
      </div>

      <div class="news-panel" if="{{ showNewsContent }}">
        <div class="lead-news {{ isDark ? 'card-dark' : 'card-light' }}" onclick="showDetail(leadNews)">
          <text class="lead-tag">{{ leadNews.category }}</text>
          <text class="lead-title {{ isDark ? 'text-dark' : 'text-light' }}">{{ leadNews.title }}</text>
          <text class="lead-desc {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ leadNews.description }}</text>
          <text class="lead-source {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ leadNews.source }} {{ leadNews.published }}</text>
        </div>
        <div class="news-grid">
          <div class="news-item {{ isDark ? 'card-dark' : 'card-light' }}" for="{{ newsList }}" onclick="showDetail($item)">
            <text class="news-item-title {{ isDark ? 'text-dark' : 'text-light' }}">{{ $item.title }}</text>
            <text class="news-item-source {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}">{{ $item.source }}</text>
          </div>
        </div>
      </div>

      <div class="data-panel {{ isDark ? 'card-dark' : 'card-light' }}" if="{{ showWeatherContent }}">
        <text class="data-kicker">{{ weatherInfo.subtitle }}</text>
        <text class="data-title {{ isDark ? 'text-dark' : 'text-light' }}">{{ weatherInfo.title }}</text>
        <text class="data-main">{{ weatherInfo.message }}</text>
        <div class="detail-list">
          <text class="detail-line {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}" for="{{ weatherInfo.details }}">{{ $item }}</text>
        </div>
      </div>

      <div class="data-panel {{ isDark ? 'card-dark' : 'card-light' }}" if="{{ showExpressContent }}">
        <text class="data-kicker">{{ expressInfo.subtitle }}</text>
        <text class="data-title {{ isDark ? 'text-dark' : 'text-light' }}">{{ expressInfo.title }}</text>
        <text class="data-main">{{ expressInfo.message }}</text>
        <div class="detail-list">
          <text class="detail-line {{ isDark ? 'text-dark-sub' : 'text-light-sub' }}" for="{{ expressInfo.details }}">{{ $item }}</text>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import router from "@system.router"
import { getLatestNews, getWeather, getExpress } from "../../common/services"

function pad(value) {
  return value < 10 ? "0" + value : "" + value
}

function emptyNews() {
  return {
    title: "暂无新闻",
    description: "请检查网络连接或 CurrentsAPI key。",
    source: "Currents",
    category: "综合",
    published: ""
  }
}

export default {
  private: {
    isDark: false,
    themeButtonText: "深色模式",
    modeLabel: "浅色",
    currentTime: "--:--",
    booted: false,
    activeTab: "news",
    activeCategory: "all",
    actionText: "刷新",
    loading: false,
    hasError: false,
    stateText: "",
    errorText: "",
    showNewsPanel: true,
    showNewsContent: false,
    showWeatherContent: false,
    showExpressContent: false,
    newsNavClass: "nav-button nav-button-active",
    weatherNavClass: "nav-button",
    expressNavClass: "nav-button",
    allCategoryClass: "category-button category-button-active",
    worldCategoryClass: "category-button",
    techCategoryClass: "category-button",
    businessCategoryClass: "category-button",
    sportsCategoryClass: "category-button",
    entertainmentCategoryClass: "category-button",
    scienceCategoryClass: "category-button",
    politicsCategoryClass: "category-button",
    healthCategoryClass: "category-button",
    leadNews: emptyNews(),
    newsList: [],
    weatherInfo: {
      title: "天气服务待配置",
      subtitle: "聚合数据-全国天气预报",
      message: "等待接口 key",
      details: ["申请 juhe.cn 天气 key 后启用。"]
    },
    expressInfo: {
      title: "快递服务待配置",
      subtitle: "聚合数据-全球快递物流查询",
      message: "等待接口 key",
      details: ["申请 juhe.cn 快递 key 后启用。"]
    }
  },

  onInit() {
    this.boot()
  },

  onShow() {
    this.boot()
  },

  boot() {
    if (this.booted) {
      return
    }
    this.booted = true
    this.updateClock()
    this.loadNewsAll()
    this.loadWeatherData()
    this.loadExpressData()
  },

  updateClock() {
    const now = new Date()
    this.currentTime = pad(now.getHours()) + ":" + pad(now.getMinutes())
  },

  toggleTheme() {
    this.isDark = !this.isDark
    this.themeButtonText = this.isDark ? "浅色模式" : "深色模式"
    this.modeLabel = this.isDark ? "深色" : "浅色"
    console.log("[InfoPlat] theme toggled, isDark: " + this.isDark)
  },

  showDetail(item) {
    if (!item || !item.title) return
    router.push({
      uri: "pages/detail",
      params: {
        title: item.title,
        description: item.description,
        source: item.source,
        url: item.url
      }
    })
  },

  refreshCurrent() {
    if (this.activeTab === "news") {
      this.reloadNews()
    } else if (this.activeTab === "weather") {
      this.loadWeatherData()
    } else {
      this.loadExpressData()
    }
  },

  showNews() {
    this.setTab("news")
    if (!this.newsList.length) {
      this.loadNewsAll()
    }
  },

  showWeather() {
    this.setTab("weather")
  },

  showExpress() {
    this.setTab("express")
  },

  setTab(tab) {
    this.activeTab = tab
    this.hasError = false
    this.showNewsPanel = tab === "news"
    this.showNewsContent = tab === "news" && !this.loading && !this.hasError
    this.showWeatherContent = tab === "weather" && !this.loading && !this.hasError
    this.showExpressContent = tab === "express" && !this.loading && !this.hasError
    this.newsNavClass = tab === "news" ? "nav-button nav-button-active" : "nav-button"
    this.weatherNavClass = tab === "weather" ? "nav-button nav-button-active" : "nav-button"
    this.expressNavClass = tab === "express" ? "nav-button nav-button-active" : "nav-button"
    this.actionText = tab === "news" ? "刷新" : "查询"
  },

  setCategory(category) {
    this.activeCategory = category
    this.allCategoryClass = category === "all" ? "category-button category-button-active" : "category-button"
    this.worldCategoryClass = category === "world" ? "category-button category-button-active" : "category-button"
    this.techCategoryClass = category === "tech" ? "category-button category-button-active" : "category-button"
    this.businessCategoryClass = category === "business" ? "category-button category-button-active" : "category-button"
    this.sportsCategoryClass = category === "sports" ? "category-button category-button-active" : "category-button"
    this.entertainmentCategoryClass = category === "entertainment" ? "category-button category-button-active" : "category-button"
    this.scienceCategoryClass = category === "science" ? "category-button category-button-active" : "category-button"
    this.politicsCategoryClass = category === "politics" ? "category-button category-button-active" : "category-button"
    this.healthCategoryClass = category === "health" ? "category-button category-button-active" : "category-button"
  },

  loadNewsAll() {
    this.setCategory("all")
    this.loadNews(["general"])
  },

  loadNewsWorld() {
    this.setCategory("world")
    this.loadNews(["world"])
  },

  loadNewsTech() {
    this.setCategory("tech")
    this.loadNews(["technology"])
  },

  loadNewsBusiness() {
    this.setCategory("business")
    this.loadNews(["business", "finance"])
  },

  loadNewsSports() {
    this.setCategory("sports")
    this.loadNews(["sports"])
  },

  loadNewsEntertainment() {
    this.setCategory("entertainment")
    this.loadNews(["entertainment"])
  },

  loadNewsScience() {
    this.setCategory("science")
    this.loadNews(["science"])
  },

  loadNewsPolitics() {
    this.setCategory("politics")
    this.loadNews(["politics"])
  },

  loadNewsHealth() {
    this.setCategory("health")
    this.loadNews(["health"])
  },

  reloadNews() {
    if (this.activeCategory === "tech") {
      this.loadNewsTech()
    } else if (this.activeCategory === "business") {
      this.loadNewsBusiness()
    } else if (this.activeCategory === "world") {
      this.loadNewsWorld()
    } else if (this.activeCategory === "sports") {
      this.loadNewsSports()
    } else if (this.activeCategory === "entertainment") {
      this.loadNewsEntertainment()
    } else if (this.activeCategory === "science") {
      this.loadNewsScience()
    } else if (this.activeCategory === "politics") {
      this.loadNewsPolitics()
    } else if (this.activeCategory === "health") {
      this.loadNewsHealth()
    } else {
      this.loadNewsAll()
    }
  },

  loadNews(categories) {
    this.setTab("news")
    this.loading = true
    this.hasError = false
    this.stateText = "正在请求新闻"
    this.showNewsContent = false
    console.log("[InfoPlat] load news " + categories.join(","))
    getLatestNews({
      categories: categories,
      pageSize: 8
    })
      .then((list) => {
        this.newsList = list.length > 1 ? list.slice(1) : []
        this.leadNews = list.length ? list[0] : emptyNews()
        this.loading = false
        this.showNewsContent = true
      })
      .catch(() => {
        this.loading = false
        this.hasError = true
        this.errorText = "新闻获取失败，请检查网络、CurrentsAPI key、分类参数和接口额度。"
      })
  },

  loadWeatherData() {
    getWeather("北京").then((info) => {
      this.weatherInfo = info
      if (this.activeTab === "weather") {
        this.showWeatherContent = true
      }
    })
  },

  loadExpressData() {
    getExpress("sf", "").then((info) => {
      this.expressInfo = info
      if (this.activeTab === "express") {
        this.showExpressContent = true
      }
    })
  }
}
</script>

<style>
