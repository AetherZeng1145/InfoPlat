  margin-top: 8px;
  font-size: 15px;
  text-overflow: ellipsis;
}

.news-grid {
  margin-top: 14px;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
}

.news-item {
  width: 257px;
  height: 100px;
  margin-bottom: 14px;
  padding: 12px;
  border-radius: 8px;
}

.news-item-title {
  height: 34px;
  font-size: 17px;
  line-height: 19px;
  font-weight: bold;
  lines: 2;
  text-overflow: ellipsis;
}

.news-item-source {
  margin-top: 7px;
  font-size: 14px;
  text-overflow: ellipsis;
}

.data-panel {
  height: 490px;
  margin-top: 18px;
  padding: 28px;
  border-radius: 8px;
  flex-direction: column;
  overflow: scroll;
}

.data-kicker {
  font-size: 18px;
  color: #0074ff;
}

.data-title {
  margin-top: 14px;
  font-size: 36px;
  font-weight: bold;
}

.data-main {
  margin-top: 14px;
  font-size: 28px;
  font-weight: bold;
  color: #0074ff;
}

.detail-list {
  margin-top: 26px;
  flex-direction: column;
}

.detail-line {
  height: 36px;
  margin-bottom: 8px;
  font-size: 22px;
  text-overflow: ellipsis;
}

.page-dark {
  background-color: #000000;
}

.main-panel-dark {
  background-color: #202020;
}

.side-bar-dark,
.card-dark {
  background-color: #171717;
}

.text-dark {
  color: #edf4f4;
}

.text-dark-sub {
  color: #aebdc2;
}

.btn-dark {
  background-color: #262626;
  color: #edf4f4;
}

.theme-btn-dark {
  background-color: #1a2c40;
  color: #6fb2ff;
}
</style>