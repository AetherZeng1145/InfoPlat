  width: 1050px;
  height: 40px;
  flex-direction: row;
}

.category-button {
  width: 96px;
  height: 36px;
  margin-right: 10px;
  border-radius: 5px;
  background-color: #e8eef0;
  color: #45565d;
  font-size: 16px;
}

.category-button-active {
  background-color: #d9ebff;
  color: #0057bf;
  font-weight: bold;
}

.state-box {
  height: 420px;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.state-title {
  font-size: 28px;
  font-weight: bold;
}

.state-text {
  width: 430px;
  margin-top: 12px;
  font-size: 20px;
  text-align: center;
}

.error-title {
  color: #9e3f3f;
}

.news-panel {
  height: 490px;
  margin-top: 18px;
  flex-direction: column;
  overflow: scroll;
}

.lead-news {
  height: 188px;
  padding: 18px;
  border-radius: 8px;
}

.lead-tag {
  font-size: 16px;
  color: #0074ff;
}

.lead-title {
  height: 62px;
  margin-top: 8px;
  font-size: 27px;
