  margin-top: 4px;
  font-size: 18px;
}

.nav-block {
  height: 176px;
  margin-top: 18px;
  flex-direction: column;
}

.nav-button {
  width: 184px;
  height: 46px;
  margin-bottom: 14px;
  border-radius: 6px;
  background-color: #e8eef0;
  color: #172026;
  font-size: 22px;
  font-weight: bold;
}

.btn-light {
  background-color: #e8eef0;
  color: #172026;
}

.nav-button-active {
  background-color: #0074ff;
  color: #ffffff;
}

.theme-btn-light {
  background-color: #e6f1ff;
  color: #0057bf;
}

.theme-button {
  width: 184px;
  height: 42px;
  border-radius: 6px;
  font-size: 19px;
  font-weight: bold;
}

.main-panel {
  width: 576px;
  height: 600px;
  padding: 24px 24px;
  flex-direction: column;
}

